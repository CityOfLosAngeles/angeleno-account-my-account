{
  "hosting": {
    "target": "HOSTING_TARGET",
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/signup",
        "destination": "https://AUTH0_DOMAIN/authorize?response_type=code&client_id=AUTH0_CLIENT_ID&redirect_uri=AUTH0_REDIRECT_URI/&screen_hint=signup",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/auth0/**",
        "function": "auth0",
        "region": "us-west1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions/auth0",
      "codebase": "auth0",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ]
}
