{
  "hosting": {
    "target": "HOSTING_TARGET",
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/assets/packages/libphonenumber_plugin/js/*.js",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/javascript"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/signup",
        "destination": "https://AUTH0_DOMAIN/authorize?response_type=code&client_id=AUTH0_CLIENT_ID&redirect_uri=AUTH0_REDIRECT_URI/&screen_hint=signup",
        "type": 301
      },
      {
        "source": ".well-known/change-password",
        "destination": "/password-change",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "/auth0/**",
        "function": "auth0",
        "region": "us-west1"
      },
      {
        "source": "!/@(js|css)/**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions/auth0",
      "codebase": "auth0",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ]
}
